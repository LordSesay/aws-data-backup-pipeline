{
  "backup_schedules": {
    "ec2_backup": {
      "description": "Nightly EBS snapshots for tagged EC2 instances",
      "schedule_expression": "cron(0 2 * * ? *)",
      "enabled": true,
      "backup_type": "ec2",
      "retention_days": 30
    },
    "cleanup": {
      "description": "Delete expired automated snapshots",
      "schedule_expression": "cron(0 4 * * ? *)",
      "enabled": true,
      "backup_type": "cleanup",
      "retention_days": 30
    },
    "rds_backup": {
      "description": "Nightly RDS snapshots (expansion module)",
      "schedule_expression": "cron(0 3 * * ? *)",
      "enabled": false,
      "backup_type": "rds",
      "retention_days": 30
    },
    "s3_backup": {
      "description": "Nightly S3 bucket sync (expansion module)",
      "schedule_expression": "cron(0 1 * * ? *)",
      "enabled": false,
      "backup_type": "s3",
      "retention_days": 30
    }
  },
  "backup_window": {
    "start_time": "01:00",
    "end_time": "05:00",
    "timezone": "UTC"
  },
  "notifications": {
    "on_success": true,
    "on_failure": true
  },
  "resource_filters": {
    "ec2": {
      "required_tags": [
        {"Key": "backup", "Value": "true"}
      ],
      "instance_states": ["running", "stopped"]
    }
  }
}
